<article class="post-card">
    <a href="{{url}}" class="post-card-link">
        <div class="post-card-image">
            {{#if feature_image}}
                <img src="{{img_url feature_image size="s"}}" alt="{{title}}" loading="lazy">
            {{/if}}
        </div>
    </a>
    <div class="post-card-body">
        {{#if primary_tag}}
            <a href="{{primary_tag.url}}" class="post-card-tag">{{primary_tag.name}}</a>
        {{/if}}
        <a href="{{url}}" class="post-card-link">
            <h3>{{title}}</h3>
        </a>
        <p class="excerpt">{{excerpt words="20"}}</p>
        <div class="post-card-meta">
            <span>{{date published_at format="MMM D, YYYY"}}</span>
            <span>&middot;</span>
            <span>{{reading_time}}</span>
        </div>
    </div>
</article>
