{{!< default}}

{{!-- Reading progress bar --}}
<div style="position:fixed;top:60px;left:0;z-index:99;height:2px;background:var(--blue);width:0%;transition:width 0.1s linear;" class="post-progress" aria-hidden="true"></div>

{{#post}}
{{!-- POST HEADER --}}
<header class="post-header" aria-labelledby="post-title">
  <div class="post-header__inner">

    <a class="post-header__back" href="{{@site.url}}">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M10 7H2M5 3L1 7l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      All articles
    </a>

    <div class="post-header__cats">
      {{#foreach tags limit="3"}}
        <a class="card__cat cat-blue" href="{{url}}">{{name}}</a>
      {{/foreach}}
      <span class="ai-chip">
        <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true"><circle cx="4.5" cy="4.5" r="3.5" stroke="currentColor" stroke-width="1"/><path d="M4.5 2.5v2l1 1" stroke="currentColor" stroke-width=".8" stroke-linecap="round"/></svg>
        AI-generated
      </span>
    </div>

    <h1 id="post-title">{{title}}</h1>

    {{#if custom_excerpt}}
      <p style="font-size:18px;color:var(--ink-2);line-height:1.65;margin:14px 0 20px;max-width:640px;">{{custom_excerpt}}</p>
    {{/if}}

    <div class="post-header__meta">
      <span>{{reading_time}}</span>
      <span class="card__meta-dot"></span>
      <span>{{date published_at format="MMMM D, YYYY"}}</span>
      {{#if updated_at}}
        <span class="card__meta-dot"></span>
        <span>Updated {{date updated_at format="MMM D, YYYY"}}</span>
      {{/if}}
    </div>

  </div>
</header>

{{!-- FEATURE IMAGE --}}
{{#if feature_image}}
<div class="post-feature-image">
  <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="eager">
</div>
{{/if}}

{{!-- POST BODY --}}
<article class="post-content" id="post-content">
  {{content}}

  {{!-- Post tags --}}
  {{#if tags}}
  <div class="post-tags">
    <span class="post-tags__label">Topics</span>
    {{#foreach tags}}
      <a class="post-tag-link" href="{{url}}">#{{name}}</a>
    {{/foreach}}
  </div>
  {{/if}}

</article>

{{!-- RELATED POSTS --}}
{{#get "posts" limit="3" filter="tags:[{{primary_tag.slug}}]+id:-{{id}}" as |related|}}
  {{#if related}}
  <section class="related-posts" aria-labelledby="related-heading">
    <div class="container">
      <p class="section-eyebrow">Related articles</p>
      <h2 id="related-heading">More on {{primary_tag.name}}</h2>
      <div class="related-grid">
        {{#foreach related}}
          <article class="card" tabindex="0">
            <div class="card__accent"></div>
            <div class="card__body">
              {{#foreach tags limit="1"}}
                <span class="card__cat cat-blue">{{name}}</span>
              {{/foreach}}
              <h4><a href="{{url}}">{{title}}</a></h4>
              <p class="card__excerpt">{{excerpt words="22"}}</p>
              <div class="card__meta">
                <span class="ai-chip">AI-generated</span>
                <span class="card__meta-dot"></span>
                <span>{{reading_time}}</span>
              </div>
            </div>
          </article>
        {{/foreach}}
      </div>
    </div>
  </section>
  {{/if}}
{{/get}}
{{/post}}

{{!-- NEWSLETTER CTA --}}
<section class="section" style="background:var(--paper-2);border-top:1px solid var(--border);">
  <div class="container--narrow">
    <div class="newsletter">
      <div>
        <p class="section-eyebrow section-eyebrow--light">Enjoyed this article?</p>
        <h2>Get weekly fastener intelligence</h2>
        <p>New standards summaries, practice guides, and industry news — one email per week. No filler.</p>
      </div>
      <div class="newsletter__form">
        <input class="newsletter__input" type="email" placeholder="your@email.com" id="post-newsletter-email">
        <button class="newsletter__submit" onclick="ghostPortalSignupPost(event)">Subscribe — it's free</button>
        <span class="newsletter__note">No spam. Unsubscribe any time.</span>
      </div>
    </div>
  </div>
</section>

<script>
function ghostPortalSignupPost(e) {
  e.preventDefault();
  var email = document.getElementById('post-newsletter-email').value;
  window.location.href = '#/portal/signup' + (email ? '?email=' + encodeURIComponent(email) : '');
}
</script>
