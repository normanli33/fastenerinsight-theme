{{!-- ═══════════════════════════════════════════
     GLOSSARY TEASER
════════════════════════════════════════════ --}}
<section class="section section--alt" id="glossary" aria-labelledby="glossary-heading">
  <div class="container">
    <div class="section__header reveal">
      <p class="section-eyebrow">Glossary</p>
      <h2 id="glossary-heading">Fastener terminology, defined</h2>
      <p>Common terms, abbreviations, and standards references — with clear, engineering-accurate definitions.</p>
    </div>

    <div class="glossary-row reveal">
      <div class="gloss-item">
        <div class="gloss-item__term">Proof load</div>
        <div class="gloss-item__def">Maximum tensile force a fastener can withstand without permanent deformation. Used for bolt selection under static loads.</div>
      </div>
      <div class="gloss-item">
        <div class="gloss-item__term">K-factor</div>
        <div class="gloss-item__def">Nut factor relating applied torque to bolt clamp load. Highly sensitive to lubrication and surface condition.</div>
      </div>
      <div class="gloss-item">
        <div class="gloss-item__term">Pitch diameter</div>
        <div class="gloss-item__def">The diameter of the imaginary coaxial cylinder where thread thickness equals the thread groove width. Critical for thread fit.</div>
      </div>
      <div class="gloss-item">
        <div class="gloss-item__term">Hydrogen embrittlement</div>
        <div class="gloss-item__def">Diffusion of hydrogen into high-strength steel during electroplating, causing sudden brittle fracture under stress. Risk increases above 10.9 grade.</div>
      </div>
    </div>

    <div style="text-align:center;margin-top:28px" class="reveal">
      <a href="{{@site.url}}/tag/glossary/" class="btn btn--ghost">Full glossary — 200+ terms →</a>
    </div>
  </div>
</section>


{{!-- ═══════════════════════════════════════════
     NEWSLETTER
════════════════════════════════════════════ --}}
<section class="section" id="newsletter" aria-labelledby="newsletter-heading">
  <div class="container--narrow">
    <div class="newsletter reveal">
      <div>
        <p class="section-eyebrow section-eyebrow--light">Newsletter</p>
        <h2 id="newsletter-heading">Weekly fastener intelligence, delivered</h2>
        <p>New standards summaries, practice guides, and industry news — one email per week. No filler. Unsubscribe any time.</p>
      </div>
      <div class="newsletter__form">
        {{!-- Ghost Portal handles actual signup; this is the visual form --}}
        <input class="newsletter__input" type="email" placeholder="your@email.com" id="newsletter-email">
        <button class="newsletter__submit" onclick="ghostPortalSignup(event)">Subscribe — it's free</button>
        <span class="newsletter__note">No spam. No ads. Unsubscribe in one click.</span>
      </div>
    </div>
  </div>
</section>

<script>
function ghostPortalSignup(e) {
  e.preventDefault();
  var email = document.getElementById('newsletter-email').value;
  if (email && window.GhostContentAPI) {
    window.location.href = '#/portal/signup?email=' + encodeURIComponent(email);
  } else {
    window.location.href = '#/portal/signup';
  }
}

function filterArticles(category, btn) {
  // Update active button
  document.querySelectorAll('.filter-btn').forEach(function(b) {
    b.classList.remove('active');
  });
  btn.classList.add('active');

  // Tag-to-category mapping
  var catMap = {
    'standards': ['standards', 'iso', 'din', 'astm', 'asme', 'iso-898', 'astm-a325', 'din-931', 'iso-4042', 'asme-b18-31-2', 'astm-f593', 'asme-b18-2-2', 'a193', 'a194', 'f593', 'f594'],
    'practice': ['engineering', 'mechanical-properties', 'socket-head-cap-screws', 'stud-bolts', 'flange-bolting', 'nuts', 'bolting', 'structural-bolts'],
    'coatings': ['coatings', 'geomet', 'dacromet', 'ruspert', 'corrosion-protection', 'iso-4042'],
    'materials': ['materials', 'stainless-steel', 'fasteners', 'iso-3506', 'en-standards'],
    'news': []
  };

  // Get all article items (cards in grid + items in list)
  var cards = document.querySelectorAll('#articles-grid article');
  var items = document.querySelectorAll('.article-item');

  function matchesCategory(tagSlug, cat) {
    if (cat === 'all') return true;
    var tags = catMap[cat] || [];
    return tags.indexOf(tagSlug) >= 0;
  }

  var visibleCount = 0;

  cards.forEach(function(card) {
    var cat = card.getAttribute('data-cat') || '';
    if (matchesCategory(cat, category)) {
      card.style.display = '';
      visibleCount++;
    } else {
      card.style.display = 'none';
    }
  });

  items.forEach(function(item) {
    var cat = item.getAttribute('data-cat') || '';
    if (matchesCategory(cat, category)) {
      item.style.display = '';
      visibleCount++;
    } else {
      item.style.display = 'none';
    }
  });

  // Show/hide the compact list section header based on whether any items are visible
  var listSection = document.querySelector('.articles-list');
  if (listSection) {
    var visibleItems = listSection.querySelectorAll('.article-item[style*=\"display: \"]');
    var anyVisible = false;
    visibleItems.forEach(function(it) {
      if (it.style.display !== 'none') anyVisible = true;
    });
    if (!anyVisible && category !== 'all') {
      // Check if all items are hidden via none
      var allHidden = true;
      listSection.querySelectorAll('.article-item').forEach(function(it) {
        var cat = it.getAttribute('data-cat') || '';
        if (matchesCategory(cat, category)) allHidden = false;
      });
      if (allHidden) listSection.style.display = 'none';
      else listSection.style.display = '';
    } else {
      listSection.style.display = '';
    }
  }
}
</script>
