{{!< default}}

{{!-- ═══════════════════════════════════════════
     HERO
════════════════════════════════════════════ --}}
<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">
    <div class="hero__text">
      <div class="hero__badge fade-up">AI-powered · Engineer-focused</div>
      <h1 id="hero-heading" class="fade-up-2">
        {{#if @custom.hero_title}}
          {{@custom.hero_title}}
        {{else}}
          The intelligent<br>guide to <em>fastener</em><br>standards &amp; practice
        {{/if}}
      </h1>
      <p class="hero__sub fade-up-3">
        {{#if @custom.hero_subtitle}}
          {{@custom.hero_subtitle}}
        {{else}}
          Deep dives into ISO, DIN, ASTM, and beyond. Torque specs, material grades, coating science, and field best practice — AI-generated, clearly explained.
        {{/if}}
      </p>
      <div class="hero__actions fade-up-4">
        <a href="#articles" class="btn btn--primary">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Browse articles
        </a>
        <a href="{{@site.url}}/tag/standards/" class="btn btn--ghost">Standards index</a>
      </div>
      <div class="hero__stats fade-up-4">
        <div>
          <div class="hero__stat-num">{{@site.posts_count}}+</div>
          <div class="hero__stat-label">Articles published</div>
        </div>
        <div>
          <div class="hero__stat-num">40+</div>
          <div class="hero__stat-label">Standards covered</div>
        </div>
        <div>
          <div class="hero__stat-num">Weekly</div>
          <div class="hero__stat-label">New content</div>
        </div>
      </div>
    </div>

    {{#if @custom.show_hero_diagram}}
    <div class="hero__visual fade-up-3" aria-hidden="true">
      <div class="hero__diagram">
        <div class="hero__diagram-header">
          <div class="hero__diagram-dot" style="background:#E2DDD3"></div>
          <div class="hero__diagram-dot" style="background:#E2DDD3"></div>
          <div class="hero__diagram-dot" style="background:#E2DDD3"></div>
          <span class="hero__diagram-title">ISO 898-1 — Property class tensile strength</span>
        </div>
        <div class="hero__diagram-body">
          <div class="grade-row">
            <div class="grade-label">4.6</div>
            <div class="grade-bar-wrap"><div class="grade-bar" style="width:30%;background:#D6E0F8"></div></div>
            <div class="grade-val">400 MPa</div>
          </div>
          <div class="grade-row">
            <div class="grade-label">5.8</div>
            <div class="grade-bar-wrap"><div class="grade-bar" style="width:38%;background:#b3c7f5"></div></div>
            <div class="grade-val">500 MPa</div>
          </div>
          <div class="grade-row">
            <div class="grade-label">8.8</div>
            <div class="grade-bar-wrap"><div class="grade-bar" style="width:60%;background:#6a94e8"></div></div>
            <div class="grade-val">800 MPa</div>
          </div>
          <div class="grade-row">
            <div class="grade-label">10.9</div>
            <div class="grade-bar-wrap"><div class="grade-bar" style="width:77%;background:#3B5FCC"></div></div>
            <div class="grade-val">1040 MPa</div>
          </div>
          <div class="grade-row">
            <div class="grade-label">12.9</div>
            <div class="grade-bar-wrap"><div class="grade-bar" style="width:94%;background:#1B3FAA"></div></div>
            <div class="grade-val">1220 MPa</div>
          </div>
        </div>
      </div>
    </div>
    {{/if}}

  </div>
</section>


{{!-- ═══════════════════════════════════════════
     ARTICLES
════════════════════════════════════════════ --}}
<section class="section" id="articles" aria-labelledby="articles-heading">
  <div class="container">

    <div class="section__header reveal">
      <p class="section-eyebrow">Latest articles</p>
      <h2 id="articles-heading">What engineers are reading</h2>
      <p>New articles published weekly. AI-generated and clearly flagged.</p>
    </div>

    {{!-- Tag filter bar --}}
    <div class="filter-bar reveal">
      <button class="filter-btn active" onclick="filterArticles('all',this)">All topics</button>
      <button class="filter-btn" onclick="filterArticles('standards',this)">Standards</button>
      <button class="filter-btn" onclick="filterArticles('practice',this)">Practice</button>
      <button class="filter-btn" onclick="filterArticles('coatings',this)">Coatings</button>
      <button class="filter-btn" onclick="filterArticles('news',this)">Industry news</button>
      <button class="filter-btn" onclick="filterArticles('materials',this)">Materials</button>
    </div>

    {{!-- Article cards grid --}}
    <div class="articles-grid reveal" id="articles-grid">

      {{#foreach posts limit="50"}}
        {{#if @first}}
          {{!-- Featured (first post) --}}
          <article class="card card--featured" data-cat="{{tags.[0].slug}}" tabindex="0">
            <div class="card__accent"></div>
            <div class="card__body">
              {{#foreach tags limit="1"}}
                <span class="card__cat cat-blue">{{name}}</span>
              {{/foreach}}
              <h3><a href="{{url}}">{{title}}</a></h3>
              <p class="card__excerpt">{{excerpt words="40"}}</p>
              <div class="card__meta">
                <span class="ai-chip">
                  <svg width="9" height="9" viewBox="0 0 9 9" fill="none" aria-hidden="true"><circle cx="4.5" cy="4.5" r="3.5" stroke="currentColor" stroke-width="1"/><path d="M4.5 2.5v2l1 1" stroke="currentColor" stroke-width=".8" stroke-linecap="round"/></svg>
                  AI-generated
                </span>
                <span class="card__meta-dot"></span>
                <span>{{reading_time}}</span>
                <span class="card__meta-dot"></span>
                <span>{{date published_at format="MMM YYYY"}}</span>
              </div>
              <a class="card__read-more" href="{{url}}">Read article
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </article>

        {{else}}
          {{!-- Regular cards --}}
          <article class="card" data-cat="{{tags.[0].slug}}" tabindex="0">
            <div class="card__accent"></div>
            <div class="card__body">
              {{#foreach tags limit="1"}}
                <span class="card__cat cat-blue">{{name}}</span>
              {{/foreach}}
              <h4><a href="{{url}}">{{title}}</a></h4>
              <p class="card__excerpt">{{excerpt words="28"}}</p>
              <div class="card__meta">
                <span class="ai-chip">AI-generated</span>
                <span class="card__meta-dot"></span>
                <span>{{reading_time}}</span>
                <span class="card__meta-dot"></span>
                <span>{{date published_at format="MMM YYYY"}}</span>
              </div>
            </div>
          </article>
        {{/if}}
      {{/foreach}}

    </div>{{!-- /articles-grid --}}

    {{!-- Compact list: remaining posts --}}
    {{#if posts.[6]}}
    <div class="articles-list reveal" style="margin-top:48px;border-top:1px solid var(--border);">
      {{#foreach posts from="7"}}
        <div class="article-item" data-cat="{{tags.[0].slug}}">
          <span class="article-item__num">{{@index}}</span>
          <div class="article-item__content">
            {{#foreach tags limit="1"}}
              <span class="card__cat cat-blue" style="font-size:10px;padding:2px 7px;margin-bottom:6px">{{name}}</span>
            {{/foreach}}
            <h4><a href="{{url}}">{{title}}</a></h4>
            <p>{{excerpt words="24"}}</p>
            <div class="article-item__meta">
              <span>{{reading_time}}</span>
              <span class="card__meta-dot"></span>
              <span>{{date published_at format="MMM D, YYYY"}}</span>
            </div>
          </div>
        </div>
      {{/foreach}}
    </div>
    {{/if}}

    {{!-- Pagination --}}
    {{#if pagination}}
    <div class="pagination reveal">
      {{#if prev_page}}<a href="{{page_url prev_page}}" aria-label="Previous page">← Newer</a>{{/if}}
      <span class="pagination__current">Page {{page}} of {{pages}}</span>
      {{#if next_page}}<a href="{{page_url next_page}}" aria-label="Next page">Older →</a>{{/if}}
    </div>
    {{/if}}

  </div>
</section>


{{!-- ═══════════════════════════════════════════
     STANDARDS INDEX (static showcase)
════════════════════════════════════════════ --}}
<section class="section section--alt" id="standards" aria-labelledby="standards-heading">
  <div class="container">
    <div class="section__header reveal">
      <p class="section-eyebrow">Standards index</p>
      <h2 id="standards-heading">Major fastener standards covered</h2>
      <p>From property classes to dimensional tolerances — every key standard, in plain language.</p>
    </div>

    <div class="standards-grid reveal">
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/iso-898/'">
        <div class="std-card__code">ISO 898</div>
        <div class="std-card__title">Mechanical properties of carbon &amp; alloy steel fasteners</div>
        <div class="std-card__desc">The foundational metric bolt standard. Covers property classes 4.6 through 12.9, proof loads, tensile strength, and marking requirements.</div>
        <div class="std-card__tags"><span class="tag">Parts 1–7</span><span class="tag">Bolts</span><span class="tag">Nuts</span><span class="tag">Set screws</span></div>
      </div>
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/astm-a325/'">
        <div class="std-card__code">ASTM A325</div>
        <div class="std-card__title">Structural bolts, steel, heat treated</div>
        <div class="std-card__desc">Imperial structural bolting standard for heavy construction. Types 1, 2, and 3 covering carbon steel, weathering steel, and alloy steel variants.</div>
        <div class="std-card__tags"><span class="tag">Structural</span><span class="tag">Type 1/3</span><span class="tag">Heavy hex</span></div>
      </div>
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/din-931/'">
        <div class="std-card__code">DIN 931</div>
        <div class="std-card__title">Hexagon head bolts — partial thread</div>
        <div class="std-card__desc">Metric partial-thread hex bolts from M3 to M52. Dimensional and tolerance data for the most commonly specified DIN fastener in European design.</div>
        <div class="std-card__tags"><span class="tag">M3–M52</span><span class="tag">Partial thread</span><span class="tag">Metric</span></div>
      </div>
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/iso-4042/'">
        <div class="std-card__code">ISO 4042</div>
        <div class="std-card__title">Electroplated coatings on fasteners</div>
        <div class="std-card__desc">Specifies thickness requirements for zinc, zinc-nickel, and cadmium electroplated coatings. The key document for corrosion protection selection.</div>
        <div class="std-card__tags"><span class="tag">Zinc</span><span class="tag">Zn-Ni</span><span class="tag">Cadmium</span><span class="tag">Plating</span></div>
      </div>
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/asme-b18-31-2/'">
        <div class="std-card__code">ASME B18.31.2</div>
        <div class="std-card__title">Continuous thread studs, double-end studs, and flange bolting</div>
        <div class="std-card__desc">Dimensional standard for stud bolts in refinery, power, and process piping. Paired with ASTM A193 B7 / A194 2H for flange bolting assemblies.</div>
        <div class="std-card__tags"><span class="tag">Stud bolts</span><span class="tag">Flange</span><span class="tag">B16.5</span></div>
      </div>
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/astm-f593/'">
        <div class="std-card__code">ASTM F593</div>
        <div class="std-card__title">Stainless steel bolts, hex cap screws, and studs</div>
        <div class="std-card__desc">Covers 18-8, 316, and duplex stainless steel fasteners in conditions CW, SH, and XH. Essential for chemical, marine, and food-industry applications.</div>
        <div class="std-card__tags"><span class="tag">Stainless</span><span class="tag">316</span><span class="tag">CW/SH/XH</span></div>
      </div>
      <div class="std-card" onclick="location.href='{{@site.url}}/tag/asme-b18-2-2/'">
        <div class="std-card__code">ASME B18.2.2</div>
        <div class="std-card__title">Heavy hex nuts for general applications — inch series</div>
        <div class="std-card__desc">Dimensional standard for heavy hex nuts, jam nuts, and slotted nuts. Pairs with stud bolts per B18.31.2 and structural bolts per F3125.</div>
        <div class="std-card__tags"><span class="tag">Heavy hex</span><span class="tag">Nuts</span><span class="tag">A194</span></div>
      </div>
    </div>

    <div style="text-align:center;margin-top:36px" class="reveal">
      <a href="{{@site.url}}/tag/standards/" class="btn btn--ghost">View full standards index →</a>
    </div>
  </div>
</section>


