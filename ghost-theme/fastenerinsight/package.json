{
  "name": "fastenerinsight",
  "description": "Custom Ghost theme for FastenerInsight — engineering specs meet procurement reality.",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=5.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "FastenerInsight"
  },
  "config": {
    "posts_per_page": 12,
    "image_sizes": {
      "xs": { "width": 300 },
      "s": { "width": 600 },
      "m": { "width": 1000 },
      "l": { "width": 1600 },
      "xl": { "width": 2000 }
    },
    "card_assets": true,
    "custom": {
      "tools_section_title": {
        "type": "text",
        "default": "Interactive Fastener Tools"
      }
    }
  }
}
